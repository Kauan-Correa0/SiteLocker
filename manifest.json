{
    "name": "SiteLocker",
    "description": "A simple extension to lock the web page for a period of time.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs"
    ],
    "web_accessible_resources": [
        {
        "resources": [
            "components/overlay/overlay.html",
            "components/overlay/overlay.css"
        ],
        "matches": ["<all_urls>"]
        }
    ],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "assets/default_icon.png"
    },
    "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["components/block.js"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}